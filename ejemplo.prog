entero edad = 25
cadena nombre = "Juan"

funcion saludar(persona: cadena, años: entero) : cadena {
    si (años >= 18) {
        retornar "Hola " + persona + ", eres mayor de edad"
    } sino {
        retornar "Hola " + persona + ", eres menor de edad"  
    }
    retornar "hola"
}

cadena mensaje = saludar(nombre, edad)
